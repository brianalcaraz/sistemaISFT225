doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Editar Usuario
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
  body
    .container.mt-5
      .row.justify-content-center
        .col-md-6.col-lg-5
          h1.mb-4.text-center Editar Usuario
          form.card.p-4.shadow-sm(action=`/updateUser/${user.id}` method="POST")
            .mb-3
              label.form-label.fw-bold(for="name") Nombre:
              input.form-control(type="text" name="name" id="name" value=user.name required)
            .mb-3
              label.form-label.fw-bold(for="email") Email:
              input.form-control(type="email" name="email" id="email" value=user.email required)
            .mb-3
              label.form-label.fw-bold(for="password") Contraseña:
              input.form-control(type="password" name="password" id="password" value=user.password required)
            button.btn.btn-primary.w-100(type="submit") Actualizar Usuario
          
          .text-center.mt-3
            a.text-decoration-none(href="/getUsers") ← Volver a la lista