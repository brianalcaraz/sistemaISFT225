doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Lista de Usuarios
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
  body
    .container.mt-5
      h1.mb-4 Lista de Usuarios
      a.btn.btn-primary.rounded-pill.px-3.mb-3(href="/registerUser") Registrar Nuevo Usuario
      br
      table.table.table-striped.table-bordered.shadow-sm
        thead.table-light
          tr
            th.text-center ID
            th.text-center Nombre
            th.text-center Email
            th.text-center Acciones
        tbody
          each user in users
            tr
              td.text-center= user.id
              td.text-center= user.name
              td.text-center= user.email
              td.d-flex.justify-content-center.gap-2
                a.btn.btn-primary.rounded-pill.px-3(href=`/editUser/${user.id}`) Editar
                form.d-inline(action=`/deleteUser/${user.id}` method="POST" onsubmit="return confirm('¿Estás seguro de eliminar este usuario?');")
                    button.btn.btn-danger.rounded-pill.px-3(type="submit") Eliminar

              