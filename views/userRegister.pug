doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    title Registrar Usuario
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
  body
    .container.mt-5
      .row.justify-content-center
        .col-md-6.col-lg-5
          h1.mb-4.text-center Registrar Nuevo Usuario
          form.card.p-4.shadow-sm(action="/createUser" method="POST")
            .mb-3
              label.form-label.fw-bold(for="id") ID:
              input.form-control(type="number" name="id" id="id" required)
            .mb-3
              label.form-label.fw-bold(for="name") Nombre:
              input.form-control(type="text" name="name" id="name" required)
            .mb-3
              label.form-label.fw-bold(for="email") Email:
              input.form-control(type="email" name="email" id="email" required)
            .mb-3
              label.form-label.fw-bold(for="password") Contraseña:
              input.form-control(type="password" name="password" id="password" required)
            button.btn.btn-success.w-100(type="submit") Guardar Usuario
          
          .text-center.mt-3
            a.text-decoration-none(href="/getUsers") ← Volver a la lista