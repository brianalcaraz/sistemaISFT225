.modal.fade#modalCrearAlumno(tabindex="-1")
  .modal-dialog.modal-lg
    .modal-content
      .modal-header.bg-info.text-white
        h5.modal-title Dar de Alta Nuevo Alumno
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      form#formCrearAlumno
        .modal-body
          .alert.alert-info.py-2.mb-4(role="alert")
            i.bi.bi-info-circle-fill.me-2
            span#textoAvisoCohorte El alumno será inscripto en la cohorte seleccionada.
          .row
            .col-6.mb-3
              label.form-label ID (Numérico)
              input.form-control(type="number" name="id" required)
            .col-6.mb-3
              label.form-label Legajo
              input.form-control(type="text" name="legajo" required)
          .mb-3
            label.form-label Nombre Completo
            input.form-control(type="text" name="name" required)
          .row
            .col-6.mb-3
              label.form-label Email
              input.form-control(type="email" name="email" required)
            .col-6.mb-3
              label.form-label Contraseña
              input.form-control(type="password" name="password" required)
          .row
            .col-6.mb-3
              label.form-label Estado
              select.form-select(name="activo" required)
                option(value="true") Activo
                option(value="false") Inactivo
            .col-6.mb-3
              label.form-label Fecha de Inscripción
              input.form-control(type="date" name="fecha_inscripcion" required)
          input(type="hidden" name="cohorte_id" id="hiddenCohorteId" value="")
        .modal-footer.bg-light
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-info.text-white(type="submit") Crear e Inscribir

.modal.fade#modalEditarAlumno(tabindex="-1")
