.modal.fade#modalCrearRegla(tabindex="-1")
  .modal-dialog
    .modal-content
      .modal-header.bg-info.text-white
        h5.modal-title Agregar Requisito
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      form#formCrearRegla
        .modal-body
          .alert.alert-info.py-2.mb-3
            span#textoAvisoMateriaRegla Agregando requisito para...
          .mb-3
            label.form-label ID de la Regla (Único)
            input.form-control(type="number" name="id" required placeholder="Ej: 501")
          input(type="hidden" name="materia_id" id="hiddenMateriaParaRegla")
          .mb-3
            label.form-label Materia Requisito
            select.form-select#selectMateriaRequisito(name="requisito_id" required)
              option(selected disabled) Cargando materias...
          .mb-3
            label.form-label Condición exigida
            select.form-select(name="tipo_requisito" required)
              option(value="Regular") Tenerla Regular
              option(value="Aprobada") Tenerla Aprobada (Final)
        .modal-footer.bg-light
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-info.text-white(type="submit") Guardar Regla

.modal.fade#modalFichaAlumno(tabindex="-1")
  .modal-dialog.modal-xl.modal-dialog-scrollable
    .modal-content
      .modal-header.bg-dark.text-white
        h5.modal-title#tituloFichaAlumno Ficha Académica
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      .modal-body.bg-light
        .card.shadow-sm.border-0.mb-4
          .card-body
            h6.text-secondary.mb-3 <i class="bi bi-graph-up me-2"></i>Progreso de la Carrera
            .progress(style="height: 25px;")
              .progress-bar.bg-success.fw-bold#barraProgresoCarrera(role="progressbar" style="width: 0%;" aria-valuenow="0" aria-valuemin="0" aria-valuemax="100") 0%
        .row
          .col-lg-8
            .card.shadow-sm.border-0.mb-4
              .card-header.bg-white.d-flex.justify-content-between.align-items-center
                h6.mb-0.text-primary <i class="bi bi-calendar-check me-2"></i>Cursadas Actuales (Inscripciones)
              .card-body.p-0#contenedorFichaInscripciones
                .p-4.text-center.text-muted Cargando inscripciones...
            .card.shadow-sm.border-0.mb-4
              .card-header.bg-white
                h6.mb-0.text-secondary <i class="bi bi-archive me-2"></i>Historial Académico (Actas y Notas)
              .card-body.p-0#contenedorFichaHistorial
                .p-4.text-center.text-muted Cargando historial...
          .col-lg-4
            .card.shadow-sm.border-0.mb-4
              .card-header.bg-white
                h6.mb-0.text-info <i class="bi bi-list-check me-2"></i>Estado por Materia
              .card-body.p-0
                .list-group.list-group-flush#contenedorFichaEstado
                  .p-4.text-center.text-muted Cargando estado académico...
      .modal-footer
        button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cerrar Expediente

.modal.fade#modalEditarActa(tabindex="-1" data-bs-backdrop="static")
  .modal-dialog.modal-sm.modal-dialog-centered
    .modal-content
      .modal-header.bg-success.text-white
        h6.modal-title Registrar Acta / Nota
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      form#formEditarActa
        .modal-body
          input(type="hidden" id="editActaRegistroId")
          input(type="hidden" id="editActaAlumnoId")
          input(type="hidden" id="editActaMateriaId")
          .mb-3
            label.form-label.small.fw-bold Estado
            select.form-select.form-select-sm#editActaEstado(name="estado" required)
              option(value="Cursando") Cursando
              option(value="Regular") Regular
              option(value="Aprobada") Aprobada
          .mb-3
            label.form-label.small.fw-bold Nota Final (Opcional)
            input.form-control.form-control-sm#editActaNota(type="number" name="nota" min="1" max="10" placeholder="Ej: 8")
        .modal-footer.bg-light
          button.btn.btn-sm.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-sm.btn-success(type="submit") Guardar

.modal.fade#modalInscribirManual(tabindex="-1")
  .modal-dialog
    .modal-content
