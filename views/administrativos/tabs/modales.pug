.modal.fade#modalCrear(tabindex="-1")
  .modal-dialog
    .modal-content
      .modal-header.bg-info.text-white
        h5.modal-title Nuevo Administrativo
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      form(action="/api/administrativos" method="POST")
        .modal-body
          .mb-3
            label.form-label ID (Numérico)
            input.form-control(type="number" name="id" required)
          .mb-3
            label.form-label Nombre
            input.form-control(type="text" name="name" required)
          .mb-3
            label.form-label Email
            input.form-control(type="email" name="email" required)
          .mb-3
            label.form-label Contraseña
            input.form-control(type="password" name="password" required)
          .row
            .col-6.mb-3
              label.form-label Área
              select.form-select(name="area" required)
                option(value="Alumnos") Alumnos
                option(value="Sistemas") Sistemas
            .col-6.mb-3
              label.form-label Rol
              select.form-select(name="rol" required)
                option(value="Admin") Admin
                option(value="Operador") Operador
        .modal-footer.bg-light
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-info.text-white(type="submit") Guardar

.modal.fade#modalEditar(tabindex="-1")
  .modal-dialog
    .modal-content
      .modal-header.bg-primary.text-white
        h5.modal-title Editar Administrativo
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      form#formEditar(method="POST")
        .modal-body
          .mb-3
            label.form-label Nombre
            input.form-control#editName(type="text" name="name" required)
          .mb-3
            label.form-label Email
            input.form-control#editEmail(type="email" name="email" required)
          .row
            .col-6.mb-3
              label.form-label Área
              select.form-select#editArea(name="area" required)
                option(value="Alumnos") Alumnos
                option(value="Sistemas") Sistemas
            .col-6.mb-3
              label.form-label Rol
              select.form-select#editRol(name="rol" required)
                option(value="Admin") Admin
                option(value="Operador") Operador
        .modal-footer.bg-light
          button.btn.btn-secondary(type="button" data-bs-dismiss="modal") Cancelar
          button.btn.btn-primary(type="submit") Actualizar Cambios

.modal.fade#modalCrearCohorte(tabindex="-1")
  .modal-dialog
    .modal-content
      .modal-header.bg-primary.text-white
        h5.modal-title Nueva Cohorte
        button.btn-close.btn-close-white(type="button" data-bs-dismiss="modal")
      form#formCrearCohorte
        .modal-body
          .mb-3
            label.form-label ID de Cohorte (Numérico)
            input.form-control(type="number" name="id" required placeholder="Ej: 1")
          .mb-3
            label.form-label Nombre / Año
