.tab-pane.fade#cohortes-pane(role="tabpanel" aria-labelledby="cohortes-tab")
  .d-flex.justify-content-between.align-items-center.mb-3
    h4.mb-0.text-secondary Gestión de Cohortes
    button.btn.btn-primary.shadow-sm(data-bs-toggle="modal" data-bs-target="#modalCrearCohorte")
      i.bi.bi-folder-plus.me-1
      | Nueva Cohorte
  
  .card.shadow-sm.border-0.mb-4
    .card-header.bg-dark.text-white.d-flex.align-items-center.justify-content-between
      .d-flex.align-items-center.gap-3
        span Seleccionar Cohorte:
        select.form-select.form-select-sm.w-auto#selectorCohorte
          option(selected disabled) Cargando cohortes...
      button.btn.btn-sm.btn-info.text-white#btnAbrirModalAlumno(data-bs-toggle="modal" data-bs-target="#modalCrearAlumno" disabled)
        i.bi.bi-person-plus.me-1
        | Dar de Alta Alumno

    .card-body.p-0#contenedorAlumnos
      .p-5.text-center.text-muted
        i.bi.bi-people.fs-1.mb-3.d-block
        h5 Seleccioná una cohorte para ver sus alumnos