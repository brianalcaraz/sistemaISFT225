script.
  let alumnosActuales = [];
  let materiasActuales = [];
  let inscripcionesActualesGlobal = []; // Array global para tener acceso rápido a las cursadas del alumno en pantalla

  function abrirModalEditar(admin) {
    document.getElementById('editName').value = admin.name;
    document.getElementById('editEmail').value = admin.email;
    document.getElementById('editArea').value = admin.area;
    document.getElementById('editRol').value = admin.rol;
    document.getElementById('formEditar').action = `/api/administrativos/editar/${admin.id}`;
    new bootstrap.Modal(document.getElementById('modalEditar')).show();
  }
  
  document.addEventListener("DOMContentLoaded", function() {
    let activeTab = localStorage.getItem('activeTab');
    if (activeTab) {
      let tabElement = document.querySelector(`button[data-bs-target="${activeTab}"]`);
      if (tabElement) new bootstrap.Tab(tabElement).show();
    }
    document.querySelectorAll('button[data-bs-toggle="tab"]').forEach(button => {
      button.addEventListener('shown.bs.tab', e => localStorage.setItem('activeTab', e.target.getAttribute('data-bs-target')));
    });
    cargarCohortes();
    cargarMaterias(); 
    cargarPeriodos();
  });

  document.getElementById('modalEditarActa').addEventListener('hidden.bs.modal', function () {
    if (document.getElementById('modalFichaAlumno').classList.contains('show')) {
      document.body.classList.add('modal-open');
    }
  });

  async function cargarCohortes() {
    const select = document.getElementById('selectorCohorte');
    try {
      const response = await fetch('/getCohortes'); 
      if(!response.ok) throw new Error('Error en el fetch de cohortes');
      const resultado = await response.json();
      select.innerHTML = '<option selected disabled>Elegir cohorte...</option>';
      if (resultado.data && resultado.data.length > 0) {
        resultado.data.forEach(cohorte => { select.innerHTML += `<option value="${cohorte.id}">${cohorte.name}</option>`; });
      } else { select.innerHTML = '<option disabled>No hay cohortes creadas</option>'; }
    } catch (error) { 
      if(select) select.innerHTML = '<option disabled>Error de conexión</option>';
      console.error("Timeout de MongoDB en Cohortes:", error); 
    }
  }

  document.getElementById('formCrearCohorte')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    try {
      const response = await fetch('/crearCohorte', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(Object.fromEntries(new FormData(e.target))) });
      if (response.ok) window.location.reload(); else alert('Error: ' + (await response.json()).error);
    } catch (error) { console.error(error); }
  });

  document.getElementById('selectorCohorte').addEventListener('change', async function(e) {
    const cohorteId = e.target.value;
    const cohorteNombre = e.target.options[e.target.selectedIndex].text;
    document.getElementById('btnAbrirModalAlumno').disabled = false;
    document.getElementById('hiddenCohorteId').value = cohorteId;
    document.getElementById('textoAvisoCohorte').innerHTML = `El alumno será inscripto automáticamente en la cohorte: <b>${cohorteNombre}</b>`;
    await dibujarTablaAlumnos(cohorteId);
  });

  async function dibujarTablaAlumnos(cohorteId) {
    const contenedor = document.getElementById('contenedorAlumnos');
    contenedor.innerHTML = '<div class="p-5 text-center"><div class="spinner-border text-primary"></div></div>';
    try {
      const response = await fetch(`/cohorte/${cohorteId}/users`);
      if(!response.ok) throw new Error('Falló el servidor');
      const resultado = await response.json();
      if (resultado.users && resultado.users.length > 0) {
        alumnosActuales = resultado.users; 
        let html = `<div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th class="ps-4">Legajo</th><th>Nombre</th><th>Email</th><th>Estado</th><th class="text-center">Acciones</th></tr></thead><tbody>`;
        resultado.users.forEach(a => {
          const badge = a.activo ? '<span class="badge bg-success">Activo</span>' : '<span class="badge bg-danger">Inactivo</span>';
          html += `<tr>
            <td class="ps-4 fw-medium">${a.legajo}</td>
            <td>${a.name}</td>
            <td>${a.email}</td>
            <td>${badge}</td>
            <td class="text-center">
              <button class="btn btn-sm btn-outline-info me-1" title="Ficha" onclick="abrirFichaAlumno(${a.id}, '${a.name}')"><i class="bi bi-card-list"></i></button>
              <button class="btn btn-sm btn-outline-success me-1" title="Inscribir" onclick="abrirModalInscripcion(${a.id}, ${cohorteId})"><i class="bi bi-plus-circle"></i></button>
              <button class="btn btn-sm btn-outline-primary me-1" onclick="abrirModalEditarAlumno(${a.id})"><i class="bi bi-pencil-square"></i></button>
              <button class="btn btn-sm btn-outline-danger" onclick="eliminarAlumnoPorCompleto(${a.id}, ${cohorteId})"><i class="bi bi-trash"></i></button>
            </td>
          </tr>`;
        });
        contenedor.innerHTML = html + '</tbody></table></div>';
      } else {
        alumnosActuales = [];
        contenedor.innerHTML = `<div class="p-5 text-center text-muted"><i class="bi bi-person-x fs-1 mb-3 d-block"></i><h5>Esta cohorte no tiene alumnos</h5></div>`;
      }
    } catch (error) { 
      contenedor.innerHTML = `<div class="p-5 text-center text-danger"><i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>Error de conexión con la base de datos.</div>`;
      console.error(error); 
    }
  }

  document.getElementById('formCrearAlumno')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    data.activo = data.activo === 'true'; 
    try {
      const response = await fetch('/createAlumno', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) {
        e.target.reset(); bootstrap.Modal.getInstance(document.getElementById('modalCrearAlumno')).hide();
        await dibujarTablaAlumnos(document.getElementById('hiddenCohorteId').value);
      } else { alert('Error: ' + (await response.json()).error); }
    } catch (error) { console.error(error); }
  });

  function abrirModalEditarAlumno(alumnoId) {
    const a = alumnosActuales.find(x => x.id === alumnoId);
    if (!a) return;
    document.getElementById('editAlumnoId').value = a.id; document.getElementById('editAlumnoLegajo').value = a.legajo;
    document.getElementById('editAlumnoName').value = a.name; document.getElementById('editAlumnoEmail').value = a.email;
    document.getElementById('editAlumnoPassword').value = ''; document.getElementById('editAlumnoActivo').value = a.activo ? 'true' : 'false';
    if (a.fecha_inscripcion) document.getElementById('editAlumnoFecha').value = a.fecha_inscripcion.split('T')[0];
    document.getElementById('formEditarAlumno').dataset.id = a.id;
    new bootstrap.Modal(document.getElementById('modalEditarAlumno')).show();
  }

  document.getElementById('formEditarAlumno')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target)); data.activo = data.activo === 'true';
    if (!data.password) delete data.password;
    try {
      const response = await fetch(`/updateAlumno/${e.target.dataset.id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) { bootstrap.Modal.getInstance(document.getElementById('modalEditarAlumno')).hide(); await dibujarTablaAlumnos(document.getElementById('hiddenCohorteId').value); } 
      else { alert('Error al actualizar el alumno.'); }
    } catch (error) { console.error(error); }
  });

  async function eliminarAlumnoPorCompleto(alumnoId, cohorteId) {
    if (!confirm('¿Eliminar por completo a este alumno?')) return;
    try {
      const response = await fetch(`/deleteAlumno/${alumnoId}`, { method: 'DELETE' });
      if (response.ok) await dibujarTablaAlumnos(cohorteId); else alert('Error al eliminar.');
    } catch (error) { console.error(error); }
  }

  // --- LÓGICA DE INSCRIPCIÓN MANUAL ---
  async function abrirModalInscripcion(alumnoId, cohorteId) {
    document.getElementById('hiddenAlumnoIdInscripcion').value = alumnoId;
    document.getElementById('hiddenCohorteIdInscripcion').value = cohorteId;
    const [resMat, resPer] = await Promise.all([fetch('/api/materias'), fetch('/api/periodos-inscripcion/activos')]);
    const materias = await resMat.json();
    const periodos = await resPer.json();
    const selM = document.getElementById('selectMateriasInscripcion');
    const selP = document.getElementById('selectPeriodosInscripcion');
    selM.innerHTML = materias.data ? materias.data.map(m => `<option value="${m.id}">${m.nombre}</option>`).join('') : '<option disabled>Sin materias</option>';
    selP.innerHTML = periodos.data && periodos.data.length > 0 ? periodos.data.map(p => `<option value="${p.id}">${p.nombre}</option>`).join('') : '<option disabled>Sin períodos activos</option>';
    new bootstrap.Modal(document.getElementById('modalInscribirManual')).show();
  }

  document.getElementById('formInscribirManual').addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const res = await fetch('/api/inscripciones', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if(res.ok) {
          bootstrap.Modal.getInstance(document.getElementById('modalInscribirManual')).hide();
          alert("Inscripción exitosa");
      } else {
          const err = await res.json();
          alert("Error: " + err.error);
      }
    } catch(e) { console.error(e); }
  });

  // --- LÓGICA DE LA FICHA ACADÉMICA ---
  function abrirFichaAlumno(alumnoId, nombreAlumno) {
    document.getElementById('tituloFichaAlumno').innerText = `Expediente Académico: ${nombreAlumno} (ID: ${alumnoId})`;
    
    // RESET COMPLETO DE CONTENEDORES PARA EVITAR PERSISTENCIA DE DATOS DE OTROS ALUMNOS
    document.getElementById('contenedorFichaEstado').innerHTML = '<div class="p-4 text-center text-muted small"><div class="spinner-border spinner-border-sm text-info me-2"></div>Cargando estado...</div>';
    document.getElementById('contenedorFichaInscripciones').innerHTML = '<div class="p-4 text-center text-muted small"><div class="spinner-border spinner-border-sm text-primary me-2"></div>Cargando inscripciones...</div>';
    document.getElementById('contenedorFichaHistorial').innerHTML = '<div class="p-4 text-center text-muted small"><div class="spinner-border spinner-border-sm text-secondary me-2"></div>Cargando historial...</div>';
    document.getElementById('barraProgresoCarrera').style.width = '0%';
    document.getElementById('barraProgresoCarrera').innerText = '0%';

    new bootstrap.Modal(document.getElementById('modalFichaAlumno')).show();
    cargarEstadoAcademico(alumnoId);
    cargarInscripcionesAlumno(alumnoId);
    cargarHistorialAlumno(alumnoId);
  }

  async function cargarEstadoAcademico(alumnoId) {
    const contenedor = document.getElementById('contenedorFichaEstado');
    const barra = document.getElementById('barraProgresoCarrera');
    try {
      const res = await fetch(`/api/estado-academico/${alumnoId}`);
      if (!res.ok) throw new Error('Error al obtener estado');
      const json = await res.json();
      barra.style.width = json.porcentaje_carrera;
      barra.innerText = json.porcentaje_carrera;
      let html = '';
      if(json.materias && json.materias.length > 0){
        json.materias.forEach(m => {
          let badge = m.estado === 'Aprobada' ? '<span class="badge bg-success rounded-pill">Aprobada</span>' : (m.estado === 'Regular' ? '<span class="badge bg-primary rounded-pill">Regular</span>' : (m.estado === 'Cursando' ? '<span class="badge bg-warning text-dark rounded-pill">Cursando</span>' : '<span class="badge bg-secondary rounded-pill">Pendiente</span>'));
          let notaVisual = m.nota ? `<br><small class="text-success fw-bold">Nota Final: ${m.nota}</small>` : '';
          html += `<div class="list-group-item d-flex justify-content-between align-items-center"><div><small class="fw-bold">${m.nombre}</small><br><small class="text-muted">${m.anio}° Año</small>${notaVisual}</div>${badge}</div>`;
        });
      }
      contenedor.innerHTML = html;
    } catch (e) { contenedor.innerHTML = `<div class="p-4 text-center text-danger small">Error de conexión.</div>`; }
  }

  async function cargarInscripcionesAlumno(alumnoId) {
    const contenedor = document.getElementById('contenedorFichaInscripciones');
    try {
      const res = await fetch(`/api/inscripciones/alumno/${alumnoId}`);
      if (!res.ok) throw new Error('Error al obtener inscripciones');
      const json = await res.json();
      if (json.data && json.data.length > 0) {
        inscripcionesActualesGlobal = json.data; // Guardamos en la variable global
        let html = `<div class="table-responsive"><table class="table table-sm table-borderless table-hover mb-0"><thead class="table-light"><tr><th class="ps-3">Materia</th><th>Período</th><th class="text-end pe-3">Acción</th></tr></thead><tbody>`;
        json.data.forEach(ins => {
          html += `<tr><td class="ps-3 pt-2 fw-medium text-primary">${ins.materia}</td><td class="pt-2"><small>${ins.periodo}</small></td><td class="text-end pe-3"><button class="btn btn-sm btn-outline-danger p-1" onclick="anularInscripcion(${ins.id}, ${alumnoId})"><i class="bi bi-x-circle"></i> Baja</button></td></tr>`;
        });
        contenedor.innerHTML = html + `</tbody></table></div>`;
      } else { 
        inscripcionesActualesGlobal = [];
        contenedor.innerHTML = `<div class="p-4 text-center text-muted small"><i class="bi bi-calendar-x fs-3 d-block mb-2"></i>El alumno no tiene cursadas activas.</div>`; 
      }
    } catch(e) { contenedor.innerHTML = `<div class="p-4 text-center text-danger small">Error de conexión.</div>`; }
  }

  async function anularInscripcion(inscripcionId, alumnoId) {
    if(!confirm('¿Dar de baja esta inscripción?')) return;
    try {
      const res = await fetch(`/api/inscripciones/${inscripcionId}`, { method: 'DELETE' });
      if(res.ok) { cargarInscripcionesAlumno(alumnoId); cargarHistorialAlumno(alumnoId); cargarEstadoAcademico(alumnoId); }
    } catch(e) { console.error(e); }
  }

  async function eliminarHistorial(registroId, alumnoId) {
    if(!confirm('¿Seguro que querés borrar este registro del historial? Esta acción no se puede deshacer.')) return;
    
    // Simulamos la ruta DELETE /api/historial/:id 
    // (Asegurate de crear este endpoint en tu historialAcademicoController si no existe)
    try {
      const res = await fetch(`/api/historial/${registroId}`, { method: 'DELETE' });
      if(res.ok) { 
        cargarHistorialAlumno(alumnoId); 
        cargarEstadoAcademico(alumnoId); 
      } else {
        const error = await res.json();
        alert('Error: ' + error.error);
      }
    } catch(e) { console.error(e); }
  }

  async function cargarHistorialAlumno(alumnoId) {
    const contenedor = document.getElementById('contenedorFichaHistorial');
    try {
      const res = await fetch(`/api/historial/alumno/${alumnoId}`);
      
      if (!res.ok) {
        contenedor.innerHTML = `<div class="p-4 text-center text-muted small"><i class="bi bi-inbox fs-3 d-block mb-2"></i>El alumno no registra antecedentes en el historial.</div>`;
        return;
      }
      
      const json = await res.json();
      if(!json.data || json.data.length === 0){
        contenedor.innerHTML = `<div class="p-4 text-center text-muted small"><i class="bi bi-inbox fs-3 d-block mb-2"></i>El alumno no registra antecedentes en el historial.</div>`;
        return;
      }
      
      let html = `<div class="table-responsive"><table class="table table-sm table-striped mb-0 align-middle"><thead class="table-light"><tr><th class="ps-3">Materia</th><th>Estado</th><th>Nota</th><th class="text-center pe-3">Acciones</th></tr></thead><tbody>`;
      json.data.forEach(h => {
        let badgeColor = h.estado === 'Aprobada' ? 'bg-success' : (h.estado === 'Regular' ? 'bg-primary' : 'bg-secondary');
        let notaNum = h.nota || ''; 
        html += `<tr>
          <td class="ps-3"><small>${h.materia}</small></td>
          <td><span class="badge ${badgeColor}">${h.estado}</span></td>
          <td class="fw-bold">${h.nota || '-'}</td>
          <td class="text-center pe-3">
            <button class="btn btn-sm btn-outline-primary py-0 px-2 me-1" title="Cargar Acta / Nota" onclick="abrirModalEditarActa(${h.id_registro}, ${alumnoId}, '${h.materia}', '${h.estado}', '${notaNum}')"><i class="bi bi-pencil"></i></button>
            <button class="btn btn-sm btn-outline-danger py-0 px-2" title="Eliminar Registro" onclick="eliminarHistorial(${h.id_registro}, ${alumnoId})"><i class="bi bi-trash"></i></button>
          </td>
        </tr>`;
      });
      contenedor.innerHTML = html + `</tbody></table></div>`;
    } catch(e) { 
      console.error(e); 
      contenedor.innerHTML = `<div class="p-4 text-center text-muted small"><i class="bi bi-inbox fs-3 d-block mb-2"></i>El alumno no registra antecedentes en el historial.</div>`;
    }
  }

  function abrirModalEditarActa(registroId, alumnoId, nombreMateria, estadoActual, notaActual) {
    document.getElementById('editActaRegistroId').value = registroId;
    document.getElementById('editActaAlumnoId').value = alumnoId;
    
    // Guardamos el nombre de la materia temporalmente en un atributo para poder cruzarlo
    document.getElementById('editActaMateriaId').dataset.materiaNombre = nombreMateria;
    
    document.getElementById('editActaEstado').value = estadoActual;
    document.getElementById('editActaNota').value = notaActual;
    new bootstrap.Modal(document.getElementById('modalEditarActa')).show();
  }

  document.getElementById('formEditarActa')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const registroId = document.getElementById('editActaRegistroId').value;
    const alumnoId = document.getElementById('editActaAlumnoId').value;
    const estadoNuevo = document.getElementById('editActaEstado').value;
    const notaValor = document.getElementById('editActaNota').value;
    const nombreMateria = document.getElementById('editActaMateriaId').dataset.materiaNombre;

    const payload = { estado: estadoNuevo, nota: notaValor ? Number(notaValor) : null };
    
    try {
      const response = await fetch(`/api/historial/${registroId}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(payload) });
      if (response.ok) { 
        // Si el admin cambió el estado a Regular o Aprobada, buscamos si el alumno tiene esa materia en Inscripciones para borrarla
        if (estadoNuevo === 'Regular' || estadoNuevo === 'Aprobada') {
           // Buscamos si existe una inscripción activa para esta misma materia
           const cursadaActiva = inscripcionesActualesGlobal.find(ins => ins.materia === nombreMateria);
           if (cursadaActiva) {
               // Si la encuentra, manda el DELETE silencioso al endpoint de inscripciones
               await fetch(`/api/inscripciones/${cursadaActiva.id}`, { method: 'DELETE' });
           }
        }

        bootstrap.Modal.getInstance(document.getElementById('modalEditarActa')).hide(); 
        cargarHistorialAlumno(alumnoId); 
        cargarEstadoAcademico(alumnoId); 
        cargarInscripcionesAlumno(alumnoId); // Refrescamos inscripciones para que desaparezca la tabla de Cursadas
      }
    } catch (error) { console.error(error); }
  });

  async function cargarMaterias() {
    const contenedor = document.getElementById('contenedorMaterias');
    try {
      const response = await fetch('/api/materias');
      if(!response.ok) throw new Error('Fallo al conectar');
      const resultado = await response.json();
      const selectVistaReglas = document.getElementById('selectorMateriaReglas');
      const selectModalRequisito = document.getElementById('selectMateriaRequisito');
      if (resultado.data && resultado.data.length > 0) {
        materiasActuales = resultado.data;
        let html = `<div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th class="ps-4">ID</th><th>Nombre</th><th>Año</th><th class="text-center">Acciones</th></tr></thead><tbody>`;
        materiasActuales.forEach(m => {
          html += `<tr><td class="ps-4 text-muted">#${m.id}</td><td class="fw-medium">${m.nombre}</td><td>${m.anio}° Año</td><td class="text-center"><button class="btn btn-sm btn-outline-warning me-1" onclick="abrirModalEditarMateria(${m.id})"><i class="bi bi-pencil"></i></button><button class="btn btn-sm btn-outline-danger" onclick="eliminarMateria(${m.id})"><i class="bi bi-trash"></i></button></td></tr>`;
        });
        if(contenedor) contenedor.innerHTML = html + '</tbody></table></div>';
        let options = '<option selected disabled>Elegir materia...</option>';
        materiasActuales.forEach(m => { options += `<option value="${m.id}">${m.nombre}</option>`; });
        if(selectVistaReglas) selectVistaReglas.innerHTML = options;
        if(selectModalRequisito) selectModalRequisito.innerHTML = options;
      } else {
        if(contenedor) contenedor.innerHTML = `<div class="p-5 text-center text-muted">Aún no hay materias registradas.</div>`;
      }
    } catch (error) { 
      if(contenedor) contenedor.innerHTML = `<div class="p-5 text-center text-danger"><i class="bi bi-exclamation-triangle fs-3 d-block mb-2"></i>Error de conexión.</div>`;
      console.error("Timeout MongoDB en Materias:", error); 
    }
  }

  document.getElementById('formCrearMateria')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const response = await fetch('/api/materias', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) { e.target.reset(); bootstrap.Modal.getInstance(document.getElementById('modalCrearMateria')).hide(); await cargarMaterias(); }
    } catch (error) { console.error(error); }
  });

  function abrirModalEditarMateria(materiaId) {
    const m = materiasActuales.find(x => x.id === materiaId);
    if (!m) return;
    document.getElementById('editMateriaId').value = m.id; document.getElementById('editMateriaNombre').value = m.nombre; document.getElementById('editMateriaAnio').value = m.anio;
    new bootstrap.Modal(document.getElementById('modalEditarMateria')).show();
  }

  document.getElementById('formEditarMateria')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('editMateriaId').value;
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const response = await fetch(`/api/materias/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) { bootstrap.Modal.getInstance(document.getElementById('modalEditarMateria')).hide(); await cargarMaterias(); }
    } catch (error) { console.error(error); }
  });

  async function eliminarMateria(id) {
    if (!confirm('¿Borrar materia?')) return;
    try {
      const response = await fetch(`/api/materias/${id}`, { method: 'DELETE' });
      if (response.ok) await cargarMaterias();
    } catch (error) { console.error(error); }
  }
  
  document.getElementById('selectorMateriaReglas')?.addEventListener('change', async function(e) {
    const id = e.target.value;
    document.getElementById('btnAbrirModalRegla').disabled = false;
    document.getElementById('hiddenMateriaParaRegla').value = id;
    document.getElementById('textoAvisoMateriaRegla').innerHTML = `Agregando requisito para: <b>${e.target.options[e.target.selectedIndex].text}</b>`;
    await dibujarTablaReglas(id);
  });

  async function dibujarTablaReglas(materiaId) {
    const contenedor = document.getElementById('contenedorReglas');
    try {
      const response = await fetch(`/api/correlatividades/materia/${materiaId}`);
      if(!response.ok) throw new Error('Error al cargar reglas');
      const resultado = await response.json();
      if (resultado.data && resultado.data.length > 0) {
        let html = `<table class="table table-sm table-borderless mb-0"><thead class="table-light"><tr><th class="ps-3">Debe tener...</th><th>Condición</th><th class="text-end pe-3">Quitar</th></tr></thead><tbody>`;
        resultado.data.forEach(regla => {
          html += `<tr><td class="ps-3 pt-2">${regla.requisito}</td><td class="pt-2"><span class="badge ${regla.condicion === 'Aprobada' ? 'bg-success' : 'bg-primary'}">${regla.condicion}</span></td><td class="text-end pe-3"><button class="btn btn-sm text-danger p-0" onclick="eliminarRegla(${regla.id_regla}, ${materiaId})"><i class="bi bi-x-circle-fill fs-5"></i></button></td></tr>`;
        });
        contenedor.innerHTML = html + '</tbody></table>';
      } else { contenedor.innerHTML = `<div class="p-4 text-center text-muted small"><i class="bi bi-check2-circle fs-3 d-block mb-2 text-success"></i>Sin requisitos.</div>`; }
    } catch (error) { 
      contenedor.innerHTML = `<div class="p-4 text-center text-danger">Error de conexión.</div>`;
      console.error(error); 
    }
  }

  document.getElementById('formCrearRegla')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const response = await fetch('/api/correlatividades', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) { e.target.reset(); bootstrap.Modal.getInstance(document.getElementById('modalCrearRegla')).hide(); await dibujarTablaReglas(data.materia_id); }
    } catch (error) { console.error(error); }
  });

  async function eliminarRegla(idRegla, materiaId) {
    if (!confirm('¿Quitar requisito?')) return;
    try {
      const response = await fetch(`/api/correlatividades/${idRegla}`, { method: 'DELETE' });
      if (response.ok) await dibujarTablaReglas(materiaId);
    } catch (error) { console.error(error); }
  }

  // =======================================================
  // --- LÓGICA DE PERÍODOS DE INSCRIPCIÓN ---
  // =======================================================
  let periodosActuales = [];

  async function cargarPeriodos() {
    const contenedor = document.getElementById('contenedorPeriodos');
    if(!contenedor) return;
    try {
      const response = await fetch('/api/periodos-inscripcion');
      if(!response.ok) throw new Error('Error al cargar');
      const resultado = await response.json();
      
      if (resultado.data && resultado.data.length > 0) {
        periodosActuales = resultado.data;
        let html = `<div class="table-responsive"><table class="table table-hover align-middle mb-0"><thead class="table-light"><tr><th class="ps-4">Nombre</th><th>Apertura</th><th>Cierre</th><th>Estado</th><th class="text-center">Acciones</th></tr></thead><tbody>`;
        
        periodosActuales.forEach(p => {
          // Formateo visual de fechas
          const fInicio = new Date(p.fechaInicio).toLocaleDateString('es-AR') + ' ' + p.horaInicio;
          const fFin = new Date(p.fechaFin).toLocaleDateString('es-AR') + ' ' + p.horaFin;
          
          // Botón switch para activar/desactivar fácil
          const botonEstado = p.activo 
            ? `<button class="btn btn-sm btn-success" onclick="togglePeriodo(${p.id}, false)">ABIERTO</button>` 
            : `<button class="btn btn-sm btn-secondary" onclick="togglePeriodo(${p.id}, true)">CERRADO</button>`;

          html += `<tr>
            <td class="ps-4 fw-medium">${p.nombre}</td>
            <td><small>${fInicio}</small></td>
            <td><small>${fFin}</small></td>
            <td>${botonEstado}</td>
            <td class="text-center">
              <button class="btn btn-sm btn-outline-warning me-1" onclick="abrirModalEditarPeriodo(${p.id})"><i class="bi bi-pencil"></i></button>
              <button class="btn btn-sm btn-outline-danger" onclick="eliminarPeriodo(${p.id})"><i class="bi bi-trash"></i></button>
            </td>
          </tr>`;
        });
        contenedor.innerHTML = html + '</tbody></table></div>';
      } else {
        periodosActuales = [];
        contenedor.innerHTML = `<div class="p-5 text-center text-muted">Aún no hay períodos creados.</div>`;
      }
    } catch (error) {
      contenedor.innerHTML = `<div class="p-5 text-center text-danger">Error de conexión.</div>`;
    }
  }

  document.getElementById('formCrearPeriodo')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const response = await fetch('/api/periodos-inscripcion', { method: 'POST', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) { 
        e.target.reset(); 
        bootstrap.Modal.getInstance(document.getElementById('modalCrearPeriodo')).hide(); 
        await cargarPeriodos(); 
      } else alert('Error: ' + (await response.json()).error);
    } catch (error) { console.error(error); }
  });

  function abrirModalEditarPeriodo(id) {
    const p = periodosActuales.find(x => x.id === id);
    if (!p) return;
    document.getElementById('editPeriodoId').value = p.id;
    document.getElementById('editPeriodoNombre').value = p.nombre;
    document.getElementById('editPeriodoFechaInicio').value = p.fechaInicio ? p.fechaInicio.split('T')[0] : '';
    document.getElementById('editPeriodoHoraInicio').value = p.horaInicio;
    document.getElementById('editPeriodoFechaFin').value = p.fechaFin ? p.fechaFin.split('T')[0] : '';
    document.getElementById('editPeriodoHoraFin').value = p.horaFin;
    new bootstrap.Modal(document.getElementById('modalEditarPeriodo')).show();
  }

  document.getElementById('formEditarPeriodo')?.addEventListener('submit', async (e) => {
    e.preventDefault();
    const id = document.getElementById('editPeriodoId').value;
    const data = Object.fromEntries(new FormData(e.target));
    try {
      const response = await fetch(`/api/periodos-inscripcion/${id}`, { method: 'PUT', headers: { 'Content-Type': 'application/json' }, body: JSON.stringify(data) });
      if (response.ok) { 
        bootstrap.Modal.getInstance(document.getElementById('modalEditarPeriodo')).hide(); 
        await cargarPeriodos(); 
      } else alert('Error al actualizar.');
    } catch (error) { console.error(error); }
  });

  async function eliminarPeriodo(id) {
    if (!confirm('¿Seguro que querés borrar este período?')) return;
    try {
      const response = await fetch(`/api/periodos-inscripcion/${id}`, { method: 'DELETE' });
      if (response.ok) await cargarPeriodos();
    } catch (error) { console.error(error); }
  }

  async function togglePeriodo(id, nuevoEstado) {
    try {
      const response = await fetch(`/api/periodos-inscripcion/${id}`, { 
        method: 'PUT', 
        headers: { 'Content-Type': 'application/json' }, 
        body: JSON.stringify({ activo: nuevoEstado }) 
      });
      if (response.ok) await cargarPeriodos();
      else alert('Error al cambiar el estado del período.');
    } catch (error) { console.error(error); }
  }