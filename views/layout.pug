doctype html
html(lang="es")
  head
    meta(charset="UTF-8")
    meta(name="viewport" content="width=device-width, initial-scale=1.0")
    title ISFT 225 - Sistema Académico
    // Bootstrap 5 CSS
    link(href="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/css/bootstrap.min.css" rel="stylesheet")
    // Bootstrap Icons (Vitales para una UX profesional)
    link(rel="stylesheet" href="https://cdn.jsdelivr.net/npm/bootstrap-icons@1.11.1/font/bootstrap-icons.css")
    style.
      /* Pequeños retoques visuales basados en tu diseño */
      .navbar-custom { background-color: #1a365d; }
      .nav-tabs-custom { background-color: #2b4c7e; }
      .nav-tabs-custom .nav-link { color: #a0aec0; border: none; }
      .nav-tabs-custom .nav-link.active { color: white; background-color: transparent; border-bottom: 3px solid #63b3ed; font-weight: bold; }
  
  body.bg-light
    // Navbar Principal
    nav.navbar.navbar-expand-lg.navbar-dark.navbar-custom
      .container-fluid.px-4
        a.navbar-brand.d-flex.align-items-center(href="/")
          i.bi.bi-journal-bookmark-fill.me-2
          | ISFT 225
        .d-flex.align-items-center.text-white
          i.bi.bi-person-circle.me-2
          span ADMIN
    
    // Acá se inyectan las demás vistas
    block contenido

    // Scripts de Bootstrap y bloque para scripts propios
    script(src="https://cdn.jsdelivr.net/npm/bootstrap@5.3.2/dist/js/bootstrap.bundle.min.js")
    block scripts